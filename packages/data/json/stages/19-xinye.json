{
  "id": "19-xinye",
  "name": "신야 철수전",
  "mapId": "xinye",
  "turnLimit": 18,
  "camera": { "zoom": 1.3, "focus": [24, 10] },
  "reward": { "gold": 1100, "exp": 0, "treasures": ["근위개"] },
