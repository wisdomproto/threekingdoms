  "scenario": {
    "intro": {
      "bg": "19-xinye-intro",
      "lines": [
        { "speaker": "유비", "side": "player", "portraitId": "유비", "text": "조조가 대군을 이끌고 내려오오. 신야를 버리고 강릉으로 물러난다." },
        { "speaker": "제갈량", "side": "player", "portraitId": "제갈량", "text": "허나 백성들이 주공을 따라나섰습니다. 십만이 넘습니다." },
        { "speaker": "유비", "side": "player", "portraitId": "유비", "text": "...버릴 수 없다. 백성을 두고는 한 걸음도 못 간다. 호위하며 간다 — 더디더라도." },
        { "speaker": "조운", "side": "player", "portraitId": "조운", "text": "제가 후미와 백성을 지키겠습니다, 주공." }
      ]
    },
    "outro": {
      "bg": "19-xinye-outro",
      "lines": [
        { "speaker": "유비", "side": "player", "portraitId": "유비", "text": "백성과 함께 강을 건넜다. 더디지만... 한 사람도 버리지 않았다." },
        { "speaker": "제갈량", "side": "player", "portraitId": "제갈량", "text": "주공의 인덕이 곧 군세입니다. 천하가 그 마음을 보고 있습니다." }
      ]
    }
  },
