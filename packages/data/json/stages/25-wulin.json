    "intro": {
      "bg": "25-wulin-intro",
      "lines": [
        { "speaker": "유비", "side": "player", "portraitId": "유비", "text": "황개 노장군이 고육계를 자청했소. 매를 맞고 거짓 항복해 조조의 선단에 불을 지른다지." },
        { "speaker": "제갈량", "side": "player", "portraitId": "제갈량", "text": "오림에 조조의 본진이 있습니다. 황개의 화선이 닿기 전, 적의 시선을 끌어야 합니다." },
        { "speaker": "관우", "side": "player", "portraitId": "관우", "text": "노장의 목숨을 건 계략입니다. 헛되이 하지 맙시다." },
        { "speaker": "유비", "side": "player", "portraitId": "유비", "text": "황개의 길을 연다. 조조의 본진을 흔들어라!" }
      ]
    },
    "outro": {
      "bg": "25-wulin-outro",
      "lines": [
        { "speaker": "황개", "side": "ally", "portraitId": "황개", "text": "이 늙은 몸의 매질이 헛되지 않았소. 불길이 강을 삼키는구려!" },
        { "speaker": "유비", "side": "player", "portraitId": "유비", "text": "노장군의 충의, 천추에 남을 것이오." }
      ]
    }
  },
