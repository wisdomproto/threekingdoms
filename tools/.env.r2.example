# R2 업로드 자격증명 — 이 파일을 저장소 루트에 .env.r2 로 복사해 채운다(.env.r2는 git 추적 안 됨).
# 버킷은 Cloudflare 대시보드에서 직접 생성. tools/upload-assets.py 가 읽는다.

# Cloudflare 계정 ID (R2 개요 페이지 / 대시보드 URL에 노출)
R2_ACCOUNT_ID=

# R2 → "API 토큰 관리"에서 발급한 S3 호환 키쌍(Object Read & Write 권한)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# 생성한 버킷 이름
R2_BUCKET=
